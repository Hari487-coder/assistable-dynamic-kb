PORT=3900
BASE_URL=http://localhost:3900          # public URL Assistable will call
DATA_DIR=./data
ENCRYPTION_KEY=                          # base64 of 32 random bytes: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
MOCK_ASSISTABLE=1                        # 1 = log v3 calls instead of sending
ASSISTABLE_API_BASE=https://apiv3.createassistants.com
NODE_ENV=development
SIGNUPS=first-only                       # self-hosted: first signup claims the instance
SETUP_TOKEN=                             # optional: first signup after a wipe must present this (env vars survive wipes)
# Optional self-restore on ephemeral disks (Render free tier wipes on redeploy).
# When the DB is empty on boot, the instance rebuilds itself from this JSON:
# BOOTSTRAP={"email":"you@x.co","password":"10+chars","assistable_api_key":"ak-...","subaccount_id":"...","sources":[{"type":"webtable","name":"Scrap Prices","url":"https://your.site/prices","schedule_minutes":60,"assistant_ids":["asst-id"]}]}
BOOTSTRAP=
